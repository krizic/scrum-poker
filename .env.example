# docker-compose environment for scrum-poker (issue #17).
#
# Copy to ".env" (auto-loaded by `docker compose`) and adjust. NEVER commit real
# secrets — this file documents variable NAMES and safe local defaults only.

# --- Postgres (db service) ---------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scrumpoker

# --- web service -------------------------------------------------------------
# Postgres connection string used by Prisma (queries + `migrate deploy`) AND by
# the direct pg LISTEN/NOTIFY realtime hub. `db` is the compose service host.
# Compose builds this from POSTGRES_* by default; override here only if needed.
# DATABASE_URL=postgresql://postgres:postgres@db:5432/scrumpoker

# Apply Prisma migrations on container start. Set to "false" to skip (e.g. when
# a separate migration job owns the schema).
RUN_MIGRATIONS=true

# --- Sentry (optional; leave blank to disable) -------------------------------
# Server-side DSN (never sent to the browser).
SENTRY_DSN=
# Browser DSN (inlined into the client bundle — public, non-sensitive only).
NEXT_PUBLIC_SENTRY_DSN=

# --- Public QR invite (PO session header) ------------------------------------
# Lets the PO share a QR code / link developers outside the local network can
# use to join. Pick ONE mode via PUBLIC_JOIN_URL_MODE:
#
#   "local" — use a fixed public domain this deployment is already reachable
#             at (e.g. a real reverse-proxied hostname). No extra container.
#             Set PUBLIC_BASE_URL below; leave the ngrok vars/profile alone.
#
#   "ngrok" — (default) resolve a temporary public URL from the `ngrok`
#             sidecar. Convenient for local dev; the URL changes every
#             restart. Requires NGROK_AUTHTOKEN below AND
#             `COMPOSE_PROFILES=ngrok` (also below) so the `ngrok` service is
#             actually started — it's skipped by default.
PUBLIC_JOIN_URL_MODE=ngrok

# Required when PUBLIC_JOIN_URL_MODE=local — the public origin developers can
# reach this deployment at, e.g. https://poker.example.com (no trailing slash).
PUBLIC_BASE_URL=

# Required when PUBLIC_JOIN_URL_MODE=ngrok. Get a free token at
# https://dashboard.ngrok.com/get-started/your-authtoken and set it here
# (never commit a real token). Leave blank to skip the feature — the `ngrok`
# compose service will simply fail to start; `db`/`web` are unaffected.
NGROK_AUTHTOKEN=
# Override only if the ngrok API is reachable at a different host/port (e.g.
# running the ngrok agent outside of docker-compose during local development).
NGROK_API_URL=http://ngrok:4040/api/tunnels

# Uncomment to actually start the `ngrok` sidecar (only needed when
# PUBLIC_JOIN_URL_MODE=ngrok — Compose reads this var itself to decide which
# optional service "profiles" to include, no `${...}` reference needed).
# COMPOSE_PROFILES=ngrok

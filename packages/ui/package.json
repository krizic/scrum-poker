{
  "name": "@scrum-poker/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Low-level, reusable UI primitives for scrum-poker built with Tailwind (utility classes only) and Radix headless primitives. Accessible, token-driven Button, Card, Input, Label, Dialog, Table, Separator, Reveal, Toast and Spinner that replace Semantic UI React. Consumed by packages/components and apps/web.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind": "./tailwind.config.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"@scrum-poker/ui: no tests yet\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@scrum-poker/config": "workspace:*",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0"
  }
}

{
  "name": "@scrum-poker/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Pure, framework-agnostic helpers for scrum-poker: vote statistics (average/min-max/distribution/consensus), pie-chart data shaping, and CSV import/export. No React/framework imports, side-effect-free. Typed against @scrum-poker/types.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@scrum-poker/types": "workspace:*",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@scrum-poker/config": "workspace:*",
    "@types/papaparse": "^5.3.7",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}

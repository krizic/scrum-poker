# apps/web environment — copy to `.env.local` and fill in. NEVER commit real secrets.
#
# Convention:
#   * Variables WITHOUT the NEXT_PUBLIC_ prefix are SERVER-ONLY. They are never
#     inlined into the browser bundle and are safe for secrets/connection strings.
#   * Variables WITH the NEXT_PUBLIC_ prefix are exposed to the browser at build
#     time. Put ONLY non-sensitive, public values here.

# --- Server-only (never sent to the browser) ---------------------------------

# Postgres connection string. Consumed by @scrum-poker/db in a later issue (#4/#7);
# unused by this scaffold but declared here so the convention is documented.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scrumpoker

# Sentry server-side DSN (falls back to NEXT_PUBLIC_SENTRY_DSN when unset).
SENTRY_DSN=

# Sentry source-map upload (build-time only). Leave blank to skip upload offline.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Public (NEXT_PUBLIC_*, inlined into the browser bundle) ------------------

# Sentry browser DSN. Safe to expose. Leave blank to disable client reporting.
NEXT_PUBLIC_SENTRY_DSN=

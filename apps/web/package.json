    "@scrum-poker/utils": "workspace:*",
    "@sentry/nextjs": "^10.67.0",
    "next": "^16.2.11",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@scrum-poker/config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.13.0",
    "postcss": "^8.5.0",
